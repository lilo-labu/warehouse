<%= form_with(model: warehouse) do |f| %>
  <% if warehouse.errors.any? %>
    <div class="price-meta" style="border-color: rgba(244,63,94,.5); color: #fecdd3;">
      <p>Проверьте поля формы:</p>
      <ul style="margin: 10px 0 0; padding-left: 18px;">
        <% warehouse.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <%= f.label :name, "Название" %>
    <%= f.text_field :name, placeholder: "Например: Основной склад" %>
  </div>

  <div class="form-field">
    <%= f.label :location, "Локация" %>
    <%= f.text_field :location, placeholder: "Город / адрес" %>
  </div>

  <div class="actions-row">
    <%= f.submit "Сохранить", class: "btn btn-primary btn-small" %>
    <%= link_to "Отмена", warehouses_path, class: "btn btn-secondary btn-small" %>
  </div>
<% end %>
