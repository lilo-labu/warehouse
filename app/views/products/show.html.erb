<div class="card-surface">
  <div class="row">
    <div>
      <h2 style="margin: 0;"><%= @product.name %></h2>
      <p class="subtitle" style="margin-top: 6px;">SKU: <%= @product.sku %> | Категория: <%= @product.category.name %></p>
    </div>
    <div class="actions-row" style="margin-top: 0;">
      <% if policy(@product).update? %>
        <%= link_to "Редактировать", edit_product_path(@product), class: "btn btn-secondary btn-small" %>
      <% end %>
      <%= link_to "К списку", products_path, class: "btn btn-secondary btn-small" %>
    </div>
  </div>
</div>

<div style="height: 16px;"></div>

<div class="card-surface">
  <h2 style="margin: 0 0 10px;">Остатки по складам</h2>
  <div class="table-wrap">
    <table>
      <thead>
      <tr>
        <th>Склад</th>
        <th>Количество</th>
      </tr>
    </thead>
    <tbody>
      <% @inventories.each do |inventory| %>
        <tr>
          <td><%= inventory.warehouse.name %></td>
          <td><%= inventory.quantity %></td>
        </tr>
      <% end %>
      <% if @inventories.empty? %>
        <tr>
          <td colspan="2" style="color:#94a3b8;">Пока нет остатков по этому товару.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
</div>
