<div class="mb-5 flex items-center justify-between">
  <h1 class="text-2xl font-bold">Категории</h1>
  <%= link_to "Новая категория", new_category_path, class: "rounded bg-cyan-600 px-4 py-2 text-white hover:bg-cyan-500" %>
</div>

<div class="overflow-hidden rounded border border-slate-800">
  <table class="min-w-full text-sm">
    <thead class="bg-slate-900 text-slate-300">
      <tr>
        <th class="px-4 py-2 text-left">Название</th>
        <th class="px-4 py-2 text-left">Действия</th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr class="border-t border-slate-800">
          <td class="px-4 py-2"><%= category.name %></td>
          <td class="px-4 py-2">
            <%= link_to "Редактировать", edit_category_path(category), class: "text-cyan-300 hover:text-cyan-200" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%== pagy_nav(@pagy) %>
</div>
