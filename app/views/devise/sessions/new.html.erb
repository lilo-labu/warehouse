<div class="auth-shell">
  <div class="auth-card">
    <h2 style="margin-top: 0;">Вход в систему</h2>
    <p class="subtitle" style="margin-top: 8px;">Введите email и пароль для доступа к складу.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-field">
        <%= f.label :email, "Email" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="form-field">
        <%= f.label :password, "Пароль" %>
        <%= f.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="margin: 10px 0;">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Запомнить меня" %>
        </div>
      <% end %>

      <div style="margin-top: 14px;">
        <%= f.submit "Войти", class: "btn btn-primary" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
